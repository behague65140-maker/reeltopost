{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Streamlit App",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    },
    {
      "name": "Webhook Stripe",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "webhook:app", "--port", "8502", "--reload"],
      "port": 8502
    }
  ]
}
